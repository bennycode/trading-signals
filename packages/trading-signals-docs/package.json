{
  "dependencies": {
    "@highcharts/react": "^5.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@typedtrader/candles": "0.1.0",
    "@typedtrader/exchange": "0.2.5",
    "highcharts": "^12.6.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "trading-signals": "7.4.3",
    "trading-strategies": "0.3.5",
    "zod": "^4.4.3"
  },
  "description": "Documentation and showcase website for trading-signals library",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.2.2"
  },
  "name": "trading-signals-docs",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "dist": "npm run build",
    "lint": "npm run lint:code && npm run lint:other",
    "lint:code": "eslint .",
    "lint:other": "npm run prettier -- --list-different",
    "prettier": "prettier --config ../../.prettierrc.json --ignore-path ../../.gitignore --ignore-path .gitignore --log-level error \"**/*.{json,scss,yml}\"",
    "start": "next start",
    "test": "npm run test:types && npm run test:units",
    "test:e2e": "playwright test",
    "test:types": "tsc --noEmit",
