{
  "bugs": {
    "url": "https://github.com/bennycode/trading-signals/issues"
  },
  "dependencies": {
    "@types/big.js": "^7.0.0",
    "axios": "^1.18.1",
    "axios-retry": "^4.5.0",
    "big.js": "^7.0.1",
    "dotenv-defaults": "^6.0.0",
    "ms": "4.0.0-nightly.202508271359",
    "ts-retry-promise": "^0.8.1",
    "zod": "^4.4.3"
  },
  "description": "Trading strategies to run trading bots with JavaScript / TypeScript.",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "!dist/start",
    "!dist/test",
    "!dist/**/*.test.*"
  ],
  "homepage": "https://bennycode.com/trading-signals",
  "keywords": [
    "trading",
    "typedtrader"
  ],
  "license": "MIT",
  "name": "@typedtrader/exchange",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "alpaca:testAll": "tsx src/broker/alpaca/demo/testAll.ts",
    "alpaca:fetchCandles": "tsx src/broker/alpaca/demo/fetchCandles.ts",
    "trading212:buy": "tsx src/broker/trading212/demo/buy.ts",
    "trading212:listBalances": "tsx src/broker/trading212/demo/listBalances.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf coverage dist",
    "dist": "npm run clean && npm run build",
    "lint": "npm run lint:code && npm run lint:other",
    "lint:code": "eslint .",
    "lint:other": "npm run prettier -- --list-different",
    "lint:types": "tsc --noEmit",
    "prettier": "prettier --config ../../.prettierrc.json --ignore-path ../../.gitignore --log-level error \"**/*.{json,scss,yml}\"",
    "start": "exit 0",
    "test": "npm run test:types && npm run test:imports && npm run test:units -- --coverage",
    "test:imports": "depcruise -c ../../.dependency-cruiser.cjs src --include-only \"^src\"",
    "test:types": "npm run lint:types",
    "test:units": "vitest run --passWithNoTests",
    "test:units:watch": "vitest --watch"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "0.2.5"
}
