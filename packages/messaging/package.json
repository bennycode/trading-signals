{
  "bugs": {
    "url": "https://github.com/bennycode/trading-signals/issues"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/conversations": "^2.1.1",
    "@typedtrader/exchange": "0.2.5",
    "@types/moment-duration-format": "2.2.7",
    "@types/node": "^25.7.0",
    "better-sqlite3": "^12.10.0",
    "better-sqlite3-multiple-ciphers": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.43.0",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2",
    "moment-timezone": "^0.6.2",
    "ms": "4.0.0-nightly.202508271359",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "trading-strategies": "0.3.5",
    "zod": "^4.4.3"
  },
  "description": "Trading bot via messaging service.",
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  },
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "!dist/start",
    "!dist/test",
    "!dist/**/*.test.*"
  ],
  "homepage": "https://bennycode.com/trading-signals",
  "keywords": [
    "messenger",
    "trading"
  ],
  "license": "MIT",
  "name": "@typedtrader/messaging",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf coverage dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "dist": "npm run clean && npm run build",
    "dev": "npm run test:types && tsx watch src/start.ts",
    "lint": "npm run lint:code && npm run lint:other",
    "lint:code": "eslint .",
    "lint:other": "npm run prettier -- --list-different",
    "lint:types": "tsc --noEmit",
    "prettier": "prettier --config ../../.prettierrc.json --ignore-path ../../.gitignore --log-level error \"**/*.{json,scss,yml}\"",
    "start": "tsx src/start.ts",
    "test": "npm run test:types && npm run test:imports && npm run test:units -- --coverage",
    "test:imports": "depcruise -c ../../.dependency-cruiser.cjs src --include-only \"^src\"",
    "test:types": "npm run lint:types",
    "test:units": "vitest run --passWithNoTests",
    "test:units:watch": "vitest --watch"
  },
  "type": "module",
  "version": "0.4.0"
}
