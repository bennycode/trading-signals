{
  "name": "@typedtrader/candles",
  "version": "0.1.0",
  "description": "Labeled market-condition candle datasets (uptrend, downtrend, sideways, …) for tests and docs.",
  "type": "module",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./json/*": "./json/*"
  },
  "files": [
    "dist",
    "json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "dist": "npm run clean && npm run build",
    "lint": "npm run lint:code && npm run lint:other",
    "lint:code": "eslint .",
    "lint:other": "npm run prettier -- --list-different",
    "prettier": "prettier --config ../../.prettierrc.json --ignore-path ../../.gitignore --log-level error \"**/*.{json,scss,yml}\"",
    "test": "npm run test:types && npm run test:imports && npm run test:units",
    "test:imports": "depcruise -c ../../.dependency-cruiser.cjs src --include-only \"^src\"",
    "test:types": "tsc --noEmit",
    "test:units": "vitest run"
  },
  "dependencies": {
    "@typedtrader/exchange": "0.2.5"
  }
}
