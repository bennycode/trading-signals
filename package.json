{
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@tstv/eslint-config": "^4.1.2",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.1",
    "jsdom": "^29.1.0",
    "lefthook": "^2.1.6",
    "lerna": "^9.0.7",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.0.14"
  },
  "name": "typedtrader",
  "private": true,
  "scripts": {
    "clean": "lerna run clean --parallel",
    "dist": "lerna run dist",
    "fix": "lerna run fix --parallel",
    "graph": "nx graph",
    "lint": "lerna run lint --parallel",
    "release": "npm install && npm run dist && lerna publish && git commit -am \"chore: update CHANGELOGs\" && git push && npm run clean",
    "start:bot": "lerna run dist --scope @typedtrader/messaging --include-dependencies && lerna run start --scope @typedtrader/messaging",
    "start:docs": "lerna run dist --scope trading-signals-docs --include-dependencies && lerna run dev --scope trading-signals-docs",
    "pretest": "lerna run dist",
    "test": "lerna run --no-sort --concurrency 8 test",
    "test:types": "lerna run --no-sort --concurrency 8 test:types"
  },
  "version": "0.0.0",
  "overrides": {
    "axios": ">=1.14.0",
    "esbuild": ">=0.25.0",
    "tar": ">=7.5.11",
    "@esbuild-kit/core-utils": {
      "esbuild": ">=0.25.0"
    }
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "optionalDependencies": {
    "encoding": "^0.1.13"
  }
}
